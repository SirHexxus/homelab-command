# terraform.tfvars.example
# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit credentials.

# Proxmox connection
proxmox_endpoint     = "https://10.0.10.X:8006/"
proxmox_api_token_id = "terraform@pam!homelab"
proxmox_api_token    = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_node         = "puppetmaster"

# Shared settings
ssh_public_key_file = "~/.ssh/homelab_ed25519.pub"
lxc_template        = "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst"
container_storage   = "local-lvm"
network_bridge      = "vmbr1"
vlan_tag            = 60

# NGINX Proxy Manager
npm_vmid        = 120
npm_hostname    = "npm"
npm_ip          = "10.0.60.10/24"
npm_gateway     = "10.0.60.1"
npm_cpu_cores   = 1
npm_memory_mb   = 1024
npm_disk_gb     = 10

# Authelia
authelia_vmid       = 121
authelia_hostname   = "authelia"
authelia_ip         = "10.0.60.11/24"
authelia_gateway    = "10.0.60.1"
authelia_cpu_cores  = 1
authelia_memory_mb  = 512
authelia_disk_gb    = 8
