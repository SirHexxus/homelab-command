# configuration.yml — managed by Ansible

theme: light

default_redirection_url: '{{ authelia_default_redirection_url }}'

jwt_secret: '{{ vault_authelia_jwt_secret }}'

server:
  host: 0.0.0.0
  port: {{ authelia_port }}

log:
  level: {{ authelia_log_level }}

totp:
  issuer: {{ authelia_session_domain }}

authentication_backend:
  file:
    path: {{ authelia_data_dir }}/users_database.yml
    password:
      algorithm: argon2id
      iterations: 3
      memory: 65536
      parallelism: 4
      key_length: 32
      salt_length: 16

access_control:
  default_policy: two_factor
  rules:
    - domain: "auth.{{ authelia_session_domain }}"
      policy: bypass
    - domain: "watch.{{ authelia_session_domain }}"
      policy: bypass
    - domain: "images.{{ authelia_session_domain }}"
      policy: bypass
    - domain: "audible.{{ authelia_session_domain }}"
      policy: bypass
    - domain: "analytics.{{ authelia_session_domain }}"
      policy: bypass

session:
  name: authelia_session
  secret: '{{ vault_authelia_session_secret }}'
  expiration: 1h
  inactivity: 5m
  domain: {{ authelia_session_domain }}

regulation:
  max_retries: 3
  find_time: 120
  ban_time: 300

storage:
  encryption_key: '{{ vault_authelia_storage_encryption_key }}'
  local:
    path: {{ authelia_data_dir }}/db.sqlite3

notifier:
  disable_startup_check: true
  filesystem:
    filename: {{ authelia_data_dir }}/notifications.txt
