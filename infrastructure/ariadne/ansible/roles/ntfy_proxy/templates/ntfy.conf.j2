# {{ ntfy_proxy_domain }}.conf — managed by Ansible
# ntfy push notification broker reverse proxy
# Upstream : http://{{ ntfy_proxy_upstream }}
# SSL      : {{ 'Let\'s Encrypt (certbot)' if ntfy_proxy_ssl else 'none — run certbot when DNS is ready' }}
#
# NOTE: proxy_buffering must be off. ntfy uses SSE for real-time delivery;
# buffered responses cause subscribers to miss or delay notifications.

server {
	listen 80;
	server_name {{ ntfy_proxy_domain }};

	client_max_body_size {{ ntfy_proxy_max_body_size }};

	# SSE: disable buffering so events reach subscribers immediately
	proxy_buffering off;

	location / {
		proxy_pass            http://{{ ntfy_proxy_upstream }};
		proxy_http_version    1.1;
		proxy_set_header      Upgrade             $http_upgrade;
		proxy_set_header      Connection          "upgrade";
		proxy_set_header      Host                $host;
		proxy_set_header      X-Real-IP           $remote_addr;
		proxy_set_header      X-Forwarded-For     $proxy_add_x_forwarded_for;
		proxy_set_header      X-Forwarded-Proto   $scheme;
		proxy_set_header      X-Accel-Buffering   "no";
		proxy_cache_bypass    $http_upgrade;
		proxy_read_timeout    300s;
		proxy_connect_timeout 10s;
	}
}
