#!/usr/bin/env bash
################################################################################
# Script Name: check-index-completeness
# Description: Finds wiki pages missing from index.md
# Author: James Stacy
# Version: 1.0.0
#
# Usage: check-index-completeness
#
# Options:
#   -h, --help      Show this help message
#
# Exit Codes:
#   0 - Success
#   1 - Configuration error
#   2 - Invalid arguments
################################################################################

set -u
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wiki-common.sh" || exit 1

show_help() {
	cat << EOF
Usage: $(basename "$0") [options]

Checks that every page in the 7 bucket directories has an entry in index.md.
Writes a report to the reports bucket if any pages are missing.

Options:
    -h, --help      Show this help message

EOF
}

main() {
	local today
	today=$(date '+%Y-%m-%d')

	local missing_count=0
	local report_lines=()

	while IFS= read -r -d '' f; do
		local title="${f##*/}"
		title="${title%.md}"
		local relative="${f#"$WIKI_DIR/"}"
		local bucket="${relative%%/*}"

		if ! grep -qF "[[${title}]]" "$INDEX_FILE" 2>/dev/null; then
			report_lines+=("- \`${relative}\` — ${bucket^^}")
			missing_count=$(( missing_count + 1 ))
		fi
	done < <(find_wiki_files)

	if [[ $missing_count -eq 0 ]]; then
		log_info "Index completeness: all pages indexed"
		return 0
	fi

	local body
	body="# Index Completeness Report — ${today}

**Issues found:** ${missing_count} pages missing from index.md

Add each page below to the correct section in index.md.

## Missing Pages

"
	local line
	for line in "${report_lines[@]}"; do
		body+="${line}"$'\n'
	done

	body+=$'\n---\n*Generated by check-index-completeness*\n'
	write_report 'index-completeness' "$today" "$body"
}

while [[ $# -gt 0 ]]; do
	case $1 in
		-h|--help) show_help; exit 0 ;;
		*)
			log_error "Unknown option: $1"
			show_help
			exit 2
			;;
	esac
done

main
