#!/usr/bin/env bash
################################################################################
# Script Name: check-orphan-files
# Description: Finds wiki pages with no inbound wikilinks from content pages
# Author: James Stacy
# Version: 1.0.0
#
# Usage: check-orphan-files [--enrich]
#
# Options:
#   -h, --help      Show this help message
#   --enrich        Use claude sonnet to suggest where to add backlinks
#                   (sonnet-4-6: wiki-wide relational reasoning required)
#
# Exit Codes:
#   0 - Success
#   1 - Configuration error
#   2 - Invalid arguments
#
# Notes:
#   journal/ pages are exempt — they are intentionally not cross-linked.
#   Pages linked only from index.md appear as orphans here; that is by
#   design so you can find pages that lack organic cross-references.
################################################################################

set -u
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wiki-common.sh" || exit 1

enrich=false

show_help() {
	cat << EOF
Usage: $(basename "$0") [options]

Scans all non-journal content pages for outbound wikilinks. Reports pages
that are never linked from any content page (organic orphans).

journal/ pages are exempt from the orphan check by design.

Options:
    -h, --help      Show this help message
    --enrich        Use claude sonnet-4-6 to suggest backlink placements

EOF
}

main() {
	local today
	today=$(date '+%Y-%m-%d')

	# Build inbound link map from content pages (not journal/, not index.md)
	declare -A inbound
	while IFS= read -r -d '' f; do
		local relative="${f#"$WIKI_DIR/"}"
		[[ $relative == journal/* ]] && continue

		while IFS= read -r link; do
			[[ -z $link ]] && continue
			inbound["$link"]=$(( ${inbound[$link]:-0} + 1 ))
		done < <(extract_wikilinks "$f")
	done < <(find_wiki_files)

	# Find orphaned pages (exclude journal/)
	local orphan_count=0
	local report_lines=()
	local orphan_titles=''

	while IFS= read -r -d '' f; do
		local title="${f##*/}"; title="${title%.md}"
		local relative="${f#"$WIKI_DIR/"}"
		[[ $relative == journal/* ]] && continue

		if [[ ${inbound[$title]:-0} -eq 0 ]]; then
			local bucket="${relative%%/*}"
			report_lines+=(
				"- [[${title}]] — ${bucket^^}"
			)
			orphan_titles+="[${bucket^^}] ${title}"$'\n'
			orphan_count=$(( orphan_count + 1 ))
		fi
	done < <(find_wiki_files)

	if [[ $orphan_count -eq 0 ]]; then
		log_info "Orphan check: no orphaned pages found"
		return 0
	fi

	local body
	body="# Orphan Files Report — ${today}

**Issues found:** ${orphan_count} pages with no inbound content links

These pages are not organically referenced from any other content page.
They may only be known via index.md. Consider whether each needs a
backlink added to an existing related page.

## Orphaned Pages

"
	local line
	for line in "${report_lines[@]}"; do
		body+="${line}"$'\n'
	done

	if [[ $enrich == true ]]; then
		if ! command -v claude &>/dev/null; then
			log_error "claude CLI not found; skipping enrichment"
		else
			log_info "Running enrichment via claude sonnet-4-6..."
			local index_sample
			index_sample=$(head -150 "$INDEX_FILE" 2>/dev/null)
			local prompt
			prompt="You are helping improve cross-linking in a personal wiki.

Orphaned pages (no other content page links to them):
${orphan_titles}

Wiki index (existing pages for reference):
${index_sample}

For each orphaned page, suggest 1-3 existing pages that logically should
link to it. Only suggest links that make genuine semantic sense.
Format one entry per orphaned page:
[[PAGE_TITLE]] -> should be linked from: PAGE1, PAGE2
If no suitable backlinks exist: [[PAGE_TITLE]] -> no obvious backlinks"

			local suggestions
			suggestions=$(claude --model "$SONNET_MODEL" \
				-p "$prompt" 2>/dev/null) \
				|| suggestions='(enrichment failed — check claude CLI)'

			body+=$'\n## Suggested Backlinks\n\n'
			body+="${suggestions}"$'\n'
		fi
	fi

	body+='
---
*Generated by check-orphan-files*
'
	write_report 'orphan-files' "$today" "$body"
}

while [[ $# -gt 0 ]]; do
	case $1 in
		-h|--help) show_help; exit 0 ;;
		--enrich) enrich=true; shift ;;
		*)
			log_error "Unknown option: $1"
			show_help
			exit 2
			;;
	esac
done

main
