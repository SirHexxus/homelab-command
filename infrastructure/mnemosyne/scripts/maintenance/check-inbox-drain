#!/usr/bin/env bash
################################################################################
# Script Name: check-inbox-drain
# Description: Alerts when files have been sitting in inbox/ too long
# Author: James Stacy
# Version: 1.0.0
#
# Usage: check-inbox-drain [--max-age N]
#
# Options:
#   -h, --help      Show this help message
#   --max-age N     Alert threshold in days (default: 3)
#
# Exit Codes:
#   0 - Success
#   1 - Configuration error
#   2 - Invalid arguments
################################################################################

set -u
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wiki-common.sh" || exit 1

max_age=3

show_help() {
	cat << EOF
Usage: $(basename "$0") [options]

Reports files in the inbox/ staging area that are older than --max-age days.
An empty inbox or all-new files produces no report.

Options:
    -h, --help      Show this help message
    --max-age N     Alert threshold in days (default: 3)

EOF
}

file_age_days() {
	local file=$1
	local mtime now
	mtime=$(stat -c %Y "$file" 2>/dev/null) || { echo 0; return; }
	now=$(date +%s)
	echo $(( (now - mtime) / 86400 ))
}

main() {
	local today
	today=$(date '+%Y-%m-%d')
	local inbox_dir="$WIKI_DIR/inbox"

	local total_count=0
	local stale_count=0
	local report_lines=()

	while IFS= read -r -d '' f; do
		local name="${f##*/}"
		[[ $name == '.gitkeep' ]] && continue
		total_count=$(( total_count + 1 ))

		local age
		age=$(file_age_days "$f")

		if (( age >= max_age )); then
			report_lines+=(
				"- \`${name}\` ŌĆö ${age} days old"
			)
			stale_count=$(( stale_count + 1 ))
		fi
	done < <(find "$inbox_dir" -maxdepth 1 -name '*.md' -print0 \
		2>/dev/null)

	if [[ $total_count -eq 0 ]]; then
		log_info "Inbox drain: inbox is empty"
		return 0
	fi

	if [[ $stale_count -eq 0 ]]; then
		log_info "Inbox drain: ${total_count} files, all within ${max_age}d"
		return 0
	fi

	local body
	body="# Inbox Drain Report ŌĆö ${today}

**Total in inbox:** ${total_count} files
**Stale (Ōēź${max_age} days):** ${stale_count} files

These files have been in inbox/ without being processed:

"
	local line
	for line in "${report_lines[@]}"; do
		body+="${line}"$'\n'
	done

	body+='
---
*Generated by check-inbox-drain*
'
	write_report 'inbox-drain' "$today" "$body"
}

while [[ $# -gt 0 ]]; do
	case $1 in
		-h|--help) show_help; exit 0 ;;
		--max-age)
			[[ -n ${2:-} ]] || {
				log_error "--max-age requires a value"
				exit 2
			}
			max_age=$2
			shift 2
			;;
		*)
			log_error "Unknown option: $1"
			show_help
			exit 2
			;;
	esac
done

main
