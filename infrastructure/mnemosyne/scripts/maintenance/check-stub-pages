#!/usr/bin/env bash
################################################################################
# Script Name: check-stub-pages
# Description: Finds wiki pages with very little body content
# Author: James Stacy
# Version: 1.0.0
#
# Usage: check-stub-pages [--min-words N] [--enrich]
#
# Options:
#   -h, --help          Show this help message
#   --min-words N       Word threshold below which a page is a stub (default: 30)
#   --enrich            Use claude haiku to judge intent and suggest content
#                       (haiku-4-5: binary judgment + brief suggestion)
#
# Exit Codes:
#   0 - Success
#   1 - Configuration error
#   2 - Invalid arguments
################################################################################

set -u
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wiki-common.sh" || exit 1

min_words=30
enrich=false

show_help() {
	cat << EOF
Usage: $(basename "$0") [options]

Finds pages whose body (excluding frontmatter) is below --min-words.
Without --enrich, all short pages are reported. With --enrich, claude
distinguishes intentionally sparse pages from genuinely incomplete ones.

Options:
    -h, --help          Show this help message
    --min-words N       Stub threshold in words (default: 30)
    --enrich            Use claude haiku-4-5 to assess each stub

EOF
}

main() {
	local today
	today=$(date '+%Y-%m-%d')

	local stub_count=0
	local report_lines=()
	local enrich_context=''

	while IFS= read -r -d '' f; do
		local relative="${f#"$WIKI_DIR/"}"
		local title="${f##*/}"; title="${title%.md}"
		local bucket="${relative%%/*}"

		local word_count
		word_count=$(count_body_words "$f")

		if (( word_count < min_words )); then
			report_lines+=(
				"### [[${title}]]"
				"- **Bucket:** ${bucket^^}  |  **Words:** ${word_count}"
				''
			)
			stub_count=$(( stub_count + 1 ))

			if [[ $enrich == true ]]; then
				local content
				content=$(cat "$f")
				enrich_context+="FILE: ${relative}"$'\n'
				enrich_context+="WORD COUNT: ${word_count}"$'\n'
				enrich_context+="CONTENT:"$'\n'
				enrich_context+="${content}"$'\n'
				enrich_context+='---'$'\n'
			fi
		fi
	done < <(find_wiki_files)

	if [[ $stub_count -eq 0 ]]; then
		log_info "Stub check: no stubs found (threshold: ${min_words} words)"
		return 0
	fi

	local body
	body="# Stub Pages Report — ${today}

**Issues found:** ${stub_count} pages under ${min_words} words
**Threshold:** ${min_words} words (body only, frontmatter excluded)

## Stub Pages

"
	local line
	for line in "${report_lines[@]}"; do
		body+="${line}"$'\n'
	done

	if [[ $enrich == true && -n $enrich_context ]]; then
		if ! command -v claude &>/dev/null; then
			log_error "claude CLI not found; skipping enrichment"
		else
			log_info "Running enrichment via claude haiku-4-5..."
			local prompt
			prompt="You are reviewing stub pages in a personal wiki.
For each page, decide if it is:
  A) Intentionally sparse (e.g. a person contact card, a link-only reference)
  B) Genuinely incomplete and needs content added

Then briefly suggest what content is missing for type B pages.

${enrich_context}

For each file output:
FILE: <relative path>
VERDICT: intentional | incomplete
SUGGESTION: <one sentence if incomplete, 'none' if intentional>"

			local assessment
			assessment=$(claude --model "$HAIKU_MODEL" \
				-p "$prompt" 2>/dev/null) \
				|| assessment='(enrichment failed — check claude CLI)'

			body+=$'\n## Stub Assessment\n\n'
			body+="${assessment}"$'\n'
		fi
	fi

	body+='
---
*Generated by check-stub-pages*
'
	write_report 'stub-pages' "$today" "$body"
}

while [[ $# -gt 0 ]]; do
	case $1 in
		-h|--help) show_help; exit 0 ;;
		--enrich) enrich=true; shift ;;
		--min-words)
			[[ -n ${2:-} ]] || {
				log_error "--min-words requires a value"
				exit 2
			}
			min_words=$2
			shift 2
			;;
		*)
			log_error "Unknown option: $1"
			show_help
			exit 2
			;;
	esac
done

main
