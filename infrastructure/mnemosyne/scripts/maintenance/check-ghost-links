#!/usr/bin/env bash
################################################################################
# Script Name: check-ghost-links
# Description: Finds wikilinks pointing to non-existent wiki pages
# Author: James Stacy
# Version: 1.0.0
#
# Usage: check-ghost-links [--enrich]
#
# Options:
#   -h, --help      Show this help message
#   --enrich        Use claude to suggest correct target filenames
#
# Exit Codes:
#   0 - Success
#   1 - Configuration error
#   2 - Invalid arguments
################################################################################

set -u
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wiki-common.sh" || exit 1

enrich=false

show_help() {
	cat << EOF
Usage: $(basename "$0") [options]

Scans all wiki pages for wikilinks pointing to non-existent pages.
Writes a report to the reports bucket if any broken links are found.

Options:
    -h, --help      Show this help message
    --enrich        Use claude haiku to suggest correct target filenames

EOF
}

# Calls claude haiku with the broken link list to suggest correct targets
enrich_results() {
	local broken_text=$1
	local -A page_titles_ref
	load_page_titles page_titles_ref
	local all_titles=''
	local title
	for title in "${!page_titles_ref[@]}"; do
		all_titles+="$title"$'\n'
	done

	local prompt
	prompt="You are helping fix broken wikilinks in a personal wiki.

Existing page titles (one per line):
${all_titles}

Broken wikilinks found (format: FILE | [[LINK]]):
${broken_text}

For each broken link, suggest the most likely matching existing page title,
or 'NO_MATCH' if none fits. One suggestion per line.
Format: [[BROKEN_LINK]] -> suggested: TITLE_OR_NO_MATCH"

	claude --model "$HAIKU_MODEL" -p "$prompt" 2>/dev/null \
		|| echo '(enrichment failed — check claude CLI)'
}

main() {
	local today
	today=$(date '+%Y-%m-%d')

	local -A page_titles
	load_page_titles page_titles

	local broken_count=0
	local report_lines=()
	local broken_for_enrich=''

	while IFS= read -r -d '' f; do
		local relative="${f#"$WIKI_DIR/"}"
		local file_broken=()

		while IFS= read -r link; do
			[[ -z $link ]] && continue
			if [[ -z ${page_titles[$link]+_} ]]; then
				file_broken+=("$link")
			fi
		done < <(extract_wikilinks "$f")

		if [[ ${#file_broken[@]} -gt 0 ]]; then
			report_lines+=("### \`${relative}\`")
			for link in "${file_broken[@]}"; do
				report_lines+=("- \`[[${link}]]\`")
				broken_for_enrich+="${relative} | [[${link}]]"$'\n'
				broken_count=$(( broken_count + 1 ))
			done
			report_lines+=('')
		fi
	done < <(find_wiki_files)

	if [[ $broken_count -eq 0 ]]; then
		log_info "Ghost link check: no broken links found"
		return 0
	fi

	local body
	body="# Ghost Links Report — ${today}

**Issues found:** ${broken_count} broken wikilinks

## Broken Wikilinks

"
	local line
	for line in "${report_lines[@]}"; do
		body+="${line}"$'\n'
	done

	if [[ $enrich == true ]]; then
		if ! command -v claude &>/dev/null; then
			log_error "claude CLI not found; skipping enrichment"
		else
			log_info "Running enrichment via claude haiku..."
			local suggestions
			suggestions=$(enrich_results "$broken_for_enrich")
			body+=$'\n## Suggested Corrections\n\n'
			body+="${suggestions}"$'\n'
		fi
	fi

	body+=$'\n---\n*Generated by check-ghost-links*\n'
	write_report 'ghost-links' "$today" "$body"
}

while [[ $# -gt 0 ]]; do
	case $1 in
		-h|--help) show_help; exit 0 ;;
		--enrich) enrich=true; shift ;;
		*)
			log_error "Unknown option: $1"
			show_help
			exit 2
			;;
	esac
done

main
