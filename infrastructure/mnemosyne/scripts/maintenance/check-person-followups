#!/usr/bin/env bash
################################################################################
# Script Name: check-person-followups
# Description: Finds PERSON pages with overdue follow-up dates
# Author: James Stacy
# Version: 1.0.0
#
# Usage: check-person-followups [--warn-days N]
#
# Options:
#   -h, --help          Show this help message
#   --warn-days N       Also flag follow-ups due within N days (default: 3)
#
# Exit Codes:
#   0 - Success
#   1 - Configuration error
#   2 - Invalid arguments
################################################################################

set -u
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wiki-common.sh" || exit 1

warn_days=3

show_help() {
	cat << EOF
Usage: $(basename "$0") [options]

Checks all PERSON pages for follow_up_needed: true with a past or
near-future follow_up_date. Writes a report if any are found.

Options:
    -h, --help          Show this help message
    --warn-days N       Also warn if follow-up is within N days (default: 3)

EOF
}

days_between() {
	local d1=$1 d2=$2
	local e1 e2
	e1=$(date -d "$d1" +%s 2>/dev/null) || { echo 0; return; }
	e2=$(date -d "$d2" +%s 2>/dev/null) || { echo 0; return; }
	echo $(( (e2 - e1) / 86400 ))
}

main() {
	local today
	today=$(date '+%Y-%m-%d')
	local warn_cutoff
	warn_cutoff=$(date -d "+${warn_days} days" '+%Y-%m-%d')

	local overdue_lines=()
	local upcoming_lines=()

	while IFS= read -r -d '' f; do
		local needed follow_date title
		needed=$(get_frontmatter_field "$f" 'follow_up_needed')
		follow_date=$(get_frontmatter_field "$f" 'follow_up_date')
		title="${f##*/}"; title="${title%.md}"

		[[ $needed == 'true' ]] || continue
		[[ -z $follow_date || $follow_date == 'null' ]] && continue

		if [[ $follow_date < $today ]]; then
			local days_ago
			days_ago=$(days_between "$follow_date" "$today")
			overdue_lines+=(
				"### [[${title}]]"
				"- **Follow-up date:** ${follow_date} (${days_ago} days ago)"
				''
			)
		elif [[ $follow_date < $warn_cutoff || \
			$follow_date == $warn_cutoff ]]; then
			local days_away
			days_away=$(days_between "$today" "$follow_date")
			upcoming_lines+=(
				"### [[${title}]]"
				"- **Follow-up date:** ${follow_date} (in ${days_away} days)"
				''
			)
		fi
	done < <(
		find "$WIKI_DIR/people" -maxdepth 1 -name '*.md' -print0 \
			2>/dev/null
	)

	local total=$(( ${#overdue_lines[@]} + ${#upcoming_lines[@]} ))
	if [[ $total -eq 0 ]]; then
		log_info "Person follow-ups: none due"
		return 0
	fi

	local body
	body="# Person Follow-ups Report — ${today}

"
	if [[ ${#overdue_lines[@]} -gt 0 ]]; then
		body+='## Overdue

'
		local line
		for line in "${overdue_lines[@]}"; do
			body+="${line}"$'\n'
		done
	fi

	if [[ ${#upcoming_lines[@]} -gt 0 ]]; then
		body+="## Due Within ${warn_days} Days

"
		local line
		for line in "${upcoming_lines[@]}"; do
			body+="${line}"$'\n'
		done
	fi

	body+='---
*Generated by check-person-followups*
'
	write_report 'person-followups' "$today" "$body"
}

while [[ $# -gt 0 ]]; do
	case $1 in
		-h|--help) show_help; exit 0 ;;
		--warn-days)
			[[ -n ${2:-} ]] || {
				log_error "--warn-days requires a value"
				exit 2
			}
			warn_days=$2
			shift 2
			;;
		*)
			log_error "Unknown option: $1"
			show_help
			exit 2
			;;
	esac
done

main
