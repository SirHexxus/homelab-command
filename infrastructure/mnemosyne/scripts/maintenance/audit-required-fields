#!/usr/bin/env bash
################################################################################
# Script Name: audit-required-fields
# Description: Finds wiki pages missing required frontmatter fields
# Author: James Stacy
# Version: 1.0.0
#
# Usage: audit-required-fields [--enrich]
#
# Options:
#   -h, --help      Show this help message
#   --enrich        Use claude haiku to infer values for missing fields
#                   (haiku-4-5: classification from short file content)
#
# Exit Codes:
#   0 - Success
#   1 - Configuration error
#   2 - Invalid arguments
################################################################################

set -u
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wiki-common.sh" || exit 1

enrich=false

show_help() {
	cat << EOF
Usage: $(basename "$0") [options]

Checks each wiki page for missing required frontmatter fields per bucket.
Writes a report if any gaps are found.

Options:
    -h, --help      Show this help message
    --enrich        Use claude haiku-4-5 to suggest values for missing fields

EOF
}

# Returns 0 if the field is present and non-empty (and not "null")
field_present() {
	local file=$1
	local field=$2
	local val
	val=$(get_frontmatter_field "$file" "$field")
	[[ -n $val && $val != 'null' ]]
}

# Checks a file for missing fields; prints one "- field" line per gap
check_fields() {
	local file=$1
	shift
	local field
	for field in "$@"; do
		if ! field_present "$file" "$field"; then
			printf -- '- `%s` missing\n' "$field"
		fi
	done
}

main() {
	local today
	today=$(date '+%Y-%m-%d')

	local gap_count=0
	local report_lines=()
	local enrich_context=''

	while IFS= read -r -d '' f; do
		local relative="${f#"$WIKI_DIR/"}"
		local bucket="${relative%%/*}"
		local gaps=''

		# Universal required fields
		gaps+=$(check_fields "$f" bucket created updated source)

		# Bucket-specific required fields
		case $bucket in
			admin)
				gaps+=$(check_fields "$f" status task_type)
				;;
			projects)
				gaps+=$(check_fields "$f" status next_action)
				;;
			pursuits)
				gaps+=$(check_fields "$f" \
					current_milestone next_milestone last_active)
				;;
			people)
				gaps+=$(check_fields "$f" relationship follow_up_needed)
				;;
		esac

		if [[ -n $gaps ]]; then
			report_lines+=("### \`${relative}\`")
			while IFS= read -r gap_line; do
				report_lines+=("$gap_line")
				gap_count=$(( gap_count + 1 ))
			done <<< "$gaps"
			report_lines+=('')

			if [[ $enrich == true ]]; then
				local content
				content=$(head -30 "$f")
				enrich_context+="FILE: ${relative}"$'\n'
				enrich_context+="MISSING: ${gaps}"$'\n'
				enrich_context+="CONTENT PREVIEW:"$'\n'
				enrich_context+="${content}"$'\n'
				enrich_context+='---'$'\n'
			fi
		fi
	done < <(find_wiki_files)

	if [[ $gap_count -eq 0 ]]; then
		log_info "Required fields: all pages complete"
		return 0
	fi

	local body
	body="# Required Fields Audit — ${today}

**Issues found:** ${gap_count} missing required fields

## Gaps by Page

"
	local line
	for line in "${report_lines[@]}"; do
		body+="${line}"$'\n'
	done

	if [[ $enrich == true && -n $enrich_context ]]; then
		if ! command -v claude &>/dev/null; then
			log_error "claude CLI not found; skipping enrichment"
		else
			log_info "Running enrichment via claude haiku-4-5..."
			local prompt
			prompt="You are filling in missing frontmatter fields in a wiki.
For each file below, infer appropriate values for the missing fields
based on the file path, bucket, and content preview.

${enrich_context}

For each file, output suggested field values in YAML format:
FILE: <relative path>
SUGGESTIONS:
  field_name: suggested_value

Only suggest values you can reasonably infer. Skip fields where
the content gives no useful signal."

			local suggestions
			suggestions=$(claude --model "$HAIKU_MODEL" \
				-p "$prompt" 2>/dev/null) \
				|| suggestions='(enrichment failed — check claude CLI)'

			body+=$'\n## Suggested Field Values\n\n'
			body+="${suggestions}"$'\n'
		fi
	fi

	body+='
---
*Generated by audit-required-fields*
'
	write_report 'required-fields' "$today" "$body"
}

while [[ $# -gt 0 ]]; do
	case $1 in
		-h|--help) show_help; exit 0 ;;
		--enrich) enrich=true; shift ;;
		*)
			log_error "Unknown option: $1"
			show_help
			exit 2
			;;
	esac
done

main
