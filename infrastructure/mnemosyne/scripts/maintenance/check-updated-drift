#!/usr/bin/env bash
################################################################################
# Script Name: check-updated-drift
# Description: Finds pages where updated: frontmatter lags behind git history
# Author: James Stacy
# Version: 1.0.0
#
# Usage: check-updated-drift [--threshold N]
#
# Options:
#   -h, --help          Show this help message
#   --threshold N       Flag drift greater than N days (default: 3)
#
# Exit Codes:
#   0 - Success
#   1 - Configuration error
#   2 - Invalid arguments
################################################################################

set -u
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wiki-common.sh" || exit 1

threshold=3

show_help() {
	cat << EOF
Usage: $(basename "$0") [options]

Compares each page's updated: frontmatter field against the date of its
last git commit. Flags pages where git is more than --threshold days newer.

Options:
    -h, --help          Show this help message
    --threshold N       Flag drift > N days (default: 3)

EOF
}

days_between() {
	local d1=$1 d2=$2
	local e1 e2
	e1=$(date -d "$d1" +%s 2>/dev/null) || { echo 0; return; }
	e2=$(date -d "$d2" +%s 2>/dev/null) || { echo 0; return; }
	echo $(( (e2 - e1) / 86400 ))
}

main() {
	local today
	today=$(date '+%Y-%m-%d')

	local drift_count=0
	local report_lines=()

	while IFS= read -r -d '' f; do
		local relative="${f#"$WIKI_DIR/"}"
		local fm_updated git_date
		fm_updated=$(get_frontmatter_field "$f" 'updated')
		git_date=$(git -C "$WIKI_DIR" log -1 --format="%as" \
			-- "$relative" 2>/dev/null)

		[[ -z $fm_updated || $fm_updated == 'null' ]] && continue
		[[ -z $git_date ]] && continue

		# Only flag when git is NEWER than frontmatter
		[[ $git_date > $fm_updated ]] || continue

		local drift
		drift=$(days_between "$fm_updated" "$git_date")
		(( drift > threshold )) || continue

		report_lines+=(
			"### \`${relative}\`"
			"- **updated:** \`${fm_updated}\`"
			"- **git last commit:** \`${git_date}\`  (${drift}d drift)"
			''
		)
		drift_count=$(( drift_count + 1 ))
	done < <(find_wiki_files)

	if [[ $drift_count -eq 0 ]]; then
		log_info "Updated drift: no stale frontmatter found"
		return 0
	fi

	local body
	body="# Updated Date Drift Report — ${today}

**Issues found:** ${drift_count} pages with stale \`updated:\` frontmatter
**Threshold:** >${threshold} days behind git

The \`updated:\` field was not incremented when these files were last committed.

## Drifted Pages

"
	local line
	for line in "${report_lines[@]}"; do
		body+="${line}"$'\n'
	done

	body+='---
*Generated by check-updated-drift*
'
	write_report 'updated-drift' "$today" "$body"
}

while [[ $# -gt 0 ]]; do
	case $1 in
		-h|--help) show_help; exit 0 ;;
		--threshold)
			[[ -n ${2:-} ]] || {
				log_error "--threshold requires a value"
				exit 2
			}
			threshold=$2
			shift 2
			;;
		*)
			log_error "Unknown option: $1"
			show_help
			exit 2
			;;
	esac
done

main
