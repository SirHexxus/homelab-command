#!/usr/bin/env bash
################################################################################
# Script Name: check-log-coverage
# Description: Finds wiki pages with no entry in log.md
# Author: James Stacy
# Version: 1.0.0
#
# Usage: check-log-coverage
#
# Exit Codes:
#   0 - Success
#   1 - Configuration error
#   2 - Invalid arguments
################################################################################

set -u
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wiki-common.sh" || exit 1

show_help() {
	cat << EOF
Usage: $(basename "$0") [options]

Checks that every wiki page title appears at least once in log.md.
Pages missing from the log were likely created outside the normal ingest flow.

Options:
    -h, --help      Show this help message

EOF
}

main() {
	local today
	today=$(date '+%Y-%m-%d')

	local missing_count=0
	local report_lines=()

	while IFS= read -r -d '' f; do
		local title="${f##*/}"
		title="${title%.md}"
		local relative="${f#"$WIKI_DIR/"}"
		local bucket="${relative%%/*}"

		if ! grep -qF "| ${title} |" "$LOG_FILE" 2>/dev/null; then
			report_lines+=(
				"- [[${title}]] — ${bucket^^}"
			)
			missing_count=$(( missing_count + 1 ))
		fi
	done < <(find_wiki_files)

	if [[ $missing_count -eq 0 ]]; then
		log_info "Log coverage: all pages have log entries"
		return 0
	fi

	local body
	body="# Log Coverage Report — ${today}

**Issues found:** ${missing_count} pages with no log.md entry

These pages were likely created without going through the standard ingest
flow. Each should have at least one \`ingest\` event added to log.md.

## Uncovered Pages

"
	local line
	for line in "${report_lines[@]}"; do
		body+="${line}"$'\n'
	done

	body+='
---
*Generated by check-log-coverage*
'
	write_report 'log-coverage' "$today" "$body"
}

while [[ $# -gt 0 ]]; do
	case $1 in
		-h|--help) show_help; exit 0 ;;
		*)
			log_error "Unknown option: $1"
			show_help
			exit 2
			;;
	esac
done

main
