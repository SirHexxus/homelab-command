#!/usr/bin/env bash
################################################################################
# Script Name: check-overdue-tasks
# Description: Finds ADMIN tasks that are Pending past their due date
# Author: James Stacy
# Version: 1.0.0
#
# Usage: check-overdue-tasks
#
# Options:
#   -h, --help      Show this help message
#
# Exit Codes:
#   0 - Success
#   1 - Configuration error
#   2 - Invalid arguments
################################################################################

set -u
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/wiki-common.sh" || exit 1

show_help() {
	cat << EOF
Usage: $(basename "$0") [options]

Checks all ADMIN tasks for Pending status past their due date.
Writes a report to the reports bucket if any overdue tasks are found.

Options:
    -h, --help      Show this help message

EOF
}

# Returns number of days between two YYYY-MM-DD dates (date2 - date1)
days_between() {
	local d1=$1 d2=$2
	local e1 e2
	e1=$(date -d "$d1" +%s 2>/dev/null) || { echo 0; return; }
	e2=$(date -d "$d2" +%s 2>/dev/null) || { echo 0; return; }
	echo $(( (e2 - e1) / 86400 ))
}

main() {
	local today
	today=$(date '+%Y-%m-%d')

	local overdue_count=0
	local user_lines=()
	local maint_lines=()

	while IFS= read -r -d '' f; do
		local status due task_type title
		status=$(get_frontmatter_field "$f" 'status')
		due=$(get_frontmatter_field "$f" 'due')
		task_type=$(get_frontmatter_field "$f" 'task_type')
		title="${f##*/}"; title="${title%.md}"

		[[ $status == 'Pending' ]] || continue
		[[ -z $due || $due == 'null' ]] && continue

		# ISO date string comparison is lexicographically correct
		[[ $due < $today ]] || continue

		local days_ago
		days_ago=$(days_between "$due" "$today")
		local entry="### [[${title}]]
- **Due:** ${due} (${days_ago} days ago)
"
		if [[ $task_type == 'user' ]]; then
			user_lines+=("$entry")
		else
			maint_lines+=("$entry")
		fi
		overdue_count=$(( overdue_count + 1 ))
	done < <(
		find "$WIKI_DIR/admin" -maxdepth 1 -name '*.md' -print0 \
			2>/dev/null
	)

	if [[ $overdue_count -eq 0 ]]; then
		log_info "Overdue tasks: none found"
		return 0
	fi

	local body
	body="# Overdue Tasks Report — ${today}

**Issues found:** ${overdue_count} overdue tasks

"
	if [[ ${#user_lines[@]} -gt 0 ]]; then
		body+='## [User] — Requires James

'
		local entry
		for entry in "${user_lines[@]}"; do
			body+="${entry}"$'\n'
		done
	fi

	if [[ ${#maint_lines[@]} -gt 0 ]]; then
		body+='## [Maintenance] — Claude Can Execute

'
		local entry
		for entry in "${maint_lines[@]}"; do
			body+="${entry}"$'\n'
		done
	fi

	body+='---
*Generated by check-overdue-tasks*
'
	write_report 'overdue-tasks' "$today" "$body"
}

while [[ $# -gt 0 ]]; do
	case $1 in
		-h|--help) show_help; exit 0 ;;
		*)
			log_error "Unknown option: $1"
			show_help
			exit 2
			;;
	esac
done

main
