#!/usr/bin/env python3
"""Process pending items in the Mnemosyne wiki inbox.

Reads JSON files from wiki/inbox/, calls claude -p with SCHEMA.md context and
the item content, then deletes the inbox file on success. On failure, leaves
the file in place for the next run.

Usage:
  process-inbox                    # git pull, then process all inbox/*.json
  process-inbox --file PATH        # process a single file (skip git pull)
  process-inbox --dry-run          # print the claude command without running
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path


# ── Constants ─────────────────────────────────────────────────────────────────

DEFAULT_WIKI_ROOT = Path.home() / "mneme" / "wiki"
INBOX_SUBDIR = "inbox"
SCHEMA_FILENAME = "SCHEMA.md"

CLAUDE_PROMPT_TEMPLATE = """\
You are the Mnemosyne Custodian — the curator and steward of this personal knowledge wiki.
Your job is to classify and integrate this inbox item into the wiki following SCHEMA.md exactly.

== SCHEMA.md ==
{schema}

== INBOX ITEM ==
Source: {source}
Content type: {raw_content_type}
Captured: {capture_ts}
{text_section}
== INSTRUCTIONS ==
1. Read index.md to check whether a relevant page already exists for this content.
2. If a matching page exists: read it, merge the new information in (extend, do not duplicate),
   update the `updated` frontmatter field, and update the index.md entry if the summary is stale.
3. If no matching page exists: create a new page in the correct bucket directory with proper
   YAML frontmatter, and add a new entry to index.md under the correct bucket section.
4. Append one line to log.md in the format:
   {{ISO-datetime}} | {{ingest|update}} | {{BUCKET}} | {{page title}} | {{source}}
5. Stage all changes (new/modified page, index.md, log.md), commit with the message:
   mneme: {{ingest|update}} {{BUCKET}} — {{page title}}
6. Push to origin.
7. Do not modify or delete the inbox JSON file — the calling script handles that.

Apply the SCHEMA.md decision framework autonomously. Do not ask for clarification unless
all three escalation conditions are met. When in doubt, classify as IDEA.
"""


# ── Helpers ───────────────────────────────────────────────────────────────────

def load_schema(wiki_root: Path) -> str:
    """Read SCHEMA.md from the wiki root."""
    schema_path = wiki_root / SCHEMA_FILENAME
    try:
        return schema_path.read_text(encoding="utf-8")
    except FileNotFoundError:
        print(f"Error: SCHEMA.md not found at {schema_path}", file=sys.stderr)
        sys.exit(1)


def build_prompt(schema: str, item: dict) -> str:
    """Build the claude -p prompt for a single inbox item."""
    text = item.get("text") or ""
    file_ref = item.get("file_ref")

    text_section_parts = []
    if text:
        text_section_parts.append(f"Text:\n{text}")
    if file_ref:
        text_section_parts.append(f"File reference: {file_ref}")
    if item.get("bucket_hint"):
        text_section_parts.append(f"Suggested bucket: {item['bucket_hint']}")
    text_section = "\n".join(text_section_parts) if text_section_parts else "(no text content)"

    return CLAUDE_PROMPT_TEMPLATE.format(
        schema=schema,
        source=item.get("source", "unknown"),
        raw_content_type=item.get("raw_content_type", "text"),
        capture_ts=item.get("capture_ts", "unknown"),
        text_section=text_section,
    )


def git_pull(wiki_root: Path) -> None:
    """Pull latest changes from origin."""
    result = subprocess.run(
        ["git", "-C", str(wiki_root), "pull", "--ff-only"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print(
            f"Warning: git pull failed (rc={result.returncode}): {result.stderr.strip()}",
            file=sys.stderr,
        )


def process_file(
    inbox_file: Path,
    wiki_root: Path,
    schema: str,
    dry_run: bool,
) -> bool:
    """Process a single inbox JSON file. Returns True on success."""
    try:
        item = json.loads(inbox_file.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError) as exc:
        print(f"Error reading {inbox_file.name}: {exc}", file=sys.stderr)
        return False

    prompt = build_prompt(schema, item)

    claude_cmd = [
        "claude",
        "-p",
        "--allowedTools", "Read,Edit,Write,Bash",
        "--print",
        prompt,
    ]

    if dry_run:
        print(f"[dry-run] Would process: {inbox_file.name}")
        print(f"[dry-run] claude -p prompt ({len(prompt)} chars):")
        print("---")
        print(prompt[:500] + "..." if len(prompt) > 500 else prompt)
        print("---")
        return True

    print(f"Processing: {inbox_file.name}", file=sys.stderr)
    result = subprocess.run(claude_cmd, capture_output=False)

    if result.returncode != 0:
        print(
            f"Error: claude -p exited {result.returncode} for {inbox_file.name} — leaving in inbox",
            file=sys.stderr,
        )
        return False

    try:
        inbox_file.unlink()
        print(f"Done: {inbox_file.name}", file=sys.stderr)
    except OSError as exc:
        print(f"Warning: could not delete {inbox_file.name}: {exc}", file=sys.stderr)

    return True


# ── Entry point ───────────────────────────────────────────────────────────────

def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--file",
        type=Path,
        metavar="PATH",
        help="Process a single inbox JSON file (skips git pull)",
    )
    parser.add_argument(
        "--wiki-root",
        type=Path,
        default=DEFAULT_WIKI_ROOT,
        metavar="DIR",
        help=f"Wiki root directory (default: {DEFAULT_WIKI_ROOT})",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the claude command without running it",
    )
    args = parser.parse_args()

    wiki_root: Path = args.wiki_root
    inbox_dir = wiki_root / INBOX_SUBDIR

    if not wiki_root.exists():
        print(f"Error: wiki root not found: {wiki_root}", file=sys.stderr)
        sys.exit(1)

    schema = load_schema(wiki_root)

    if args.file:
        target = args.file
        if not target.exists():
            print(f"Error: file not found: {target}", file=sys.stderr)
            sys.exit(1)
        ok = process_file(target, wiki_root, schema, args.dry_run)
        sys.exit(0 if ok else 1)

    # No --file: pull first, then process all pending inbox items
    if not args.dry_run:
        git_pull(wiki_root)

    inbox_files = sorted(inbox_dir.glob("*.json"))
    if not inbox_files:
        print("Inbox is empty.", file=sys.stderr)
        sys.exit(0)

    print(f"Found {len(inbox_files)} inbox item(s).", file=sys.stderr)
    failed = 0
    for inbox_file in inbox_files:
        ok = process_file(inbox_file, wiki_root, schema, args.dry_run)
        if not ok:
            failed += 1

    if failed:
        print(f"{failed} item(s) failed — check logs above.", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
