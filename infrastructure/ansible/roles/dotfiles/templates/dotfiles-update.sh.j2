#!/bin/bash
# /etc/profile.d/dotfiles-update.sh
# Managed by Ansible - do not edit manually
#
# Silently pull the latest dotfiles in the background on interactive login.

DOTFILES_GIT_DIR="$HOME/.dotfiles"

# $PS1 being set means this is an interactive shell.
# The bare repo must exist (i.e. dotfiles were provisioned).
if [[ -n "$PS1" && -d "$DOTFILES_GIT_DIR" ]]; then
    git --git-dir="$DOTFILES_GIT_DIR" --work-tree="$HOME" pull --quiet 2>/dev/null &
fi
