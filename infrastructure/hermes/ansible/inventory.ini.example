# inventory.ini.example - Ansible Host Inventory
#
# Copy this file to inventory.ini and update the IP address:
#   cp inventory.ini.example inventory.ini
#
# Update the IP address after running Terraform.

[hermes_containers]
hermes-01 ansible_host=10.0.50.17 ansible_user=root ansible_port=22

[hermes_containers:vars]
# SSH configuration
ansible_ssh_private_key_file = ~/.ssh/id_rsa
ansible_ssh_common_args = '-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'

# Python interpreter
ansible_python_interpreter = /usr/bin/python3

# Connection settings
ansible_connection_timeout = 30

# Privilege escalation
ansible_become = true
ansible_become_user = root
ansible_become_method = sudo
