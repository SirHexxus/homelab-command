#!/usr/bin/env python3
"""Hermes API server — starts the minimal HTTP interface for n8n integration.

Usage:
  hermes-api
  hermes-api --port 8765 --context personal
  hermes-api --host 0.0.0.0 --debug

Requires:
  HERMES_API_TOKEN  Bearer token for POST /task auth (set in env or Ansible Vault inject)

Routes:
  GET  /health  — no auth; used by Ansible verify step and Uptime Kuma
  POST /task    — Bearer token required; accepts {workflow, task, payload, context_name}
"""

import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent.parent))

import lib.skills.filesystem  # noqa: F401, E402 — side-effect: registers filesystem skills
import lib.skills.shell       # noqa: F401, E402 — side-effect: registers shell skills
import lib.skills.wiki        # noqa: F401, E402 — side-effect: registers wiki skills

from lib.core.context import get_default_context_name  # noqa: E402
from lib.interfaces.api import create_app               # noqa: E402

HERMES_VERSION = "0.1.0"


def main() -> None:
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--port", type=int, default=8765, help="Port to listen on (default: 8765)")
    parser.add_argument(
        "--host",
        default="127.0.0.1",
        help="Host to bind to (default: 127.0.0.1 — use 0.0.0.0 only behind a proxy)",
    )
    parser.add_argument("--context", "-c", default=None, metavar="NAME",
                        help="Default context name (default: from config.yml)")
    parser.add_argument("--debug", action="store_true", help="Enable Flask debug mode")
    args = parser.parse_args()

    context_name = args.context or get_default_context_name()
    app = create_app(default_context_name=context_name)

    print(f"Hermes API {HERMES_VERSION}")
    print(f"Listening on http://{args.host}:{args.port}")
    print(f"Default context: {context_name}")
    print("Auth: HERMES_API_TOKEN env var (required for POST /task)")

    app.run(host=args.host, port=args.port, debug=args.debug)


if __name__ == "__main__":
    main()
