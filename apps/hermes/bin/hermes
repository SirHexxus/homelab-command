#!/usr/bin/env python3
"""Hermes — local AI agent for homelab and personal automation.

Usage examples:
  hermes "list files in ~/personal/downloads"
  hermes --context professional --dry-run "move all PDFs in ~/projects/ to ~/projects/archive/"
  hermes --context personal --interactive
  hermes --usage
"""

import argparse
import sys
from pathlib import Path

# Allow importing from lib/ when running from the project root or bin/
sys.path.insert(0, str(Path(__file__).parent.parent))

# ── Imports (after path setup) ─────────────────────────────────────────────────
# These imports live here (not at module top) because they depend on sys.path
from lib.core.agent_loop import run_agent  # noqa: E402
from lib.core.audit import print_usage_summary  # noqa: E402
from lib.core.context import get_default_context_name, load_context  # noqa: E402

# Trigger skill auto-registration by importing the skill modules
import lib.skills.filesystem  # noqa: F401, E402
import lib.skills.mneme  # noqa: F401, E402
import lib.skills.shell  # noqa: F401, E402

# ── Constants ──────────────────────────────────────────────────────────────────
HERMES_VERSION = "0.1.0"


# ── Helpers ────────────────────────────────────────────────────────────────────

def run_interactive(context_name: str, dry_run: bool, verbose: bool) -> None:
    """Start an interactive REPL session.

    Args:
        context_name: Name of the context to load.
        dry_run: Whether to run in dry-run mode.
        verbose: Whether to print step-by-step reasoning.
    """
    context = load_context(context_name)
    dry_note = " [DRY RUN]" if dry_run else ""
    print(f"Hermes {HERMES_VERSION} — {context.display_name}{dry_note}")
    print("Type your task and press Enter. Type 'exit' or Ctrl-D to quit.\n")

    while True:
        try:
            task = input("hermes> ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if not task:
            continue
        if task.lower() in ("exit", "quit", "q"):
            break

        result = run_agent(task, context, dry_run=dry_run, verbose=verbose)
        print(f"\n{result.answer}\n")


def run_oneshot(
    task: str,
    context_name: str,
    dry_run: bool,
    verbose: bool,
) -> None:
    """Execute a single task and print the result.

    Args:
        task: The natural-language task string.
        context_name: Name of the context to load.
        dry_run: Whether to run in dry-run mode.
        verbose: Whether to print step reasoning to stderr.
    """
    context = load_context(context_name)
    result = run_agent(task, context, dry_run=dry_run, verbose=verbose)
    print(result.answer)


# ── CLI ────────────────────────────────────────────────────────────────────────

def main() -> None:
    """Entry point."""
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "task",
        nargs="?",
        default=None,
        help="Task to execute (omit to use --interactive or --usage)",
    )
    parser.add_argument(
        "--context", "-c",
        default=None,
        metavar="NAME",
        help="Context name to use (default: value of default_context in config.yml)",
    )
    parser.add_argument(
        "--interactive", "-i",
        action="store_true",
        help="Start an interactive REPL session",
    )
    parser.add_argument(
        "--usage",
        action="store_true",
        help="Print today's per-model call counts and exit",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Describe planned actions without executing them",
    )
    parser.add_argument(
        "--verbose", "-v",
        action="store_true",
        help="Print each agent step's reasoning to stderr",
    )
    parser.add_argument(
        "--version",
        action="version",
        version=f"Hermes {HERMES_VERSION}",
    )
    args = parser.parse_args()

    # --usage: print audit summary and exit
    if args.usage:
        print_usage_summary()
        return

    # Resolve context name
    context_name = args.context or get_default_context_name()

    # --interactive: REPL mode
    if args.interactive:
        run_interactive(context_name, dry_run=args.dry_run, verbose=args.verbose)
        return

    # One-shot mode: task required
    if not args.task:
        parser.print_help()
        sys.exit(1)

    run_oneshot(args.task, context_name, dry_run=args.dry_run, verbose=args.verbose)


if __name__ == "__main__":
    main()
